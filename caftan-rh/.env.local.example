NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=CaftanRH <noreply@yourdomain.com>

# Resend Inbound (Vague 1) — webhook signature validation
# Configure ce secret dans le tableau de bord Resend (Webhooks → Signing secret).
# Sans cette variable, /api/inbound retourne 503 mais /api/inbound/test fonctionne.
RESEND_INBOUND_SECRET=
INBOUND_PARSE_DOMAIN=parse.caftanfactory.example

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gravity Forms (WordPress) — config initiale (peut être éditée via /admin/integrations/gravity-forms)
GF_WP_URL=https://yourdomain.com
GF_CK=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GF_CS=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GF_FORM_ID=4

# Cron sync secret (random long string ; aussi à mettre sur Vercel)
CRON_SECRET=replace-me-with-long-random-string

# Anthropic API (Vague 3 — IA)
# Sans cette clé, runAgent() retourne { ok: false, error: 'AI provider not configured' }
# sans crash, et l'Inbox d'actions IA affiche les actions de démo seedées via
# `npm run seed:agent-demo`.
ANTHROPIC_API_KEY=

# WhatsApp via Twilio (configurer aussi dans /admin/integrations/whatsapp)
# TWILIO_WEBHOOK_BASE_URL est utilisé pour calculer l'URL du webhook inbound
# affichée dans la page de configuration. En prod : https://votre-app.vercel.app
# En local (dev), laisse vide ou utilise un tunnel ngrok / cloudflared.
TWILIO_WEBHOOK_BASE_URL=https://your-app.vercel.app
# Si défini à "1" : ignore la validation X-Twilio-Signature (uniquement pour
# debug local — laisse vide en production).
TWILIO_SKIP_SIGNATURE_VALIDATION=

# WebPush (notifications push PWA) — génère via `npm run vapid:generate`.
# Sans ces clés, les push sont silencieux mais l'app fonctionne normalement.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:hr@caftanfactory.com
